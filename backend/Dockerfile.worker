FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git nmap wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Trivy (SCA + IaC scanner) ────────────────────────────────────────────────
RUN curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh \
    | sh -s -- -b /usr/local/bin

# ── TruffleHog (secrets scanner) ─────────────────────────────────────────────
RUN curl -sSfL https://raw.githubusercontent.com/trufflesecurity/trufflehog/main/scripts/install.sh \
    | sh -s -- -b /usr/local/bin

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir strix-ai

# ── Semgrep (SAST) + Checkov (IaC) — Python packages ────────────────────────
RUN pip install --no-cache-dir semgrep checkov

COPY . .

RUN mkdir -p /var/zentinel/scans

ENV PYTHONUNBUFFERED=1
ENV STRIX_LLM=vertex_ai/gemini-2.5-pro
ENV STRIX_TELEMETRY=false

# concurrency=2 = 2 parallel scans per worker instance
# Strix handles its own Docker sandbox per scan — nuked after each test
CMD ["celery", "-A", "app.workers.tasks.celery_app", "worker", \
     "--loglevel=info", "--concurrency=2", "-Q", "scans"]
